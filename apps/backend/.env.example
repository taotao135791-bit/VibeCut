# ── LLM Provider ──────────────────────────────────────────────
# "gemini" or "openai"
MRDV2_LLM_PROVIDER=gemini

# ── Gemini ────────────────────────────────────────────────────
MRDV2_GEMINI_API_KEY=your-gemini-api-key-here
MRDV2_GEMINI_BASE_URL=
MRDV2_GEMINI_MODEL=gemini-2.5-flash

# ── OpenAI-compatible (DeepSeek / Qwen / OpenRouter 等) ──────
# MRDV2_OPENAI_API_KEY=sk-xxx
# MRDV2_OPENAI_BASE_URL=https://api.deepseek.com/v1
# MRDV2_OPENAI_MODEL=gpt-4o
# Thinking/reasoning mode: off | dashscope | deepseek
# MRDV2_OPENAI_THINKING=off

# ── Vision Provider (视频/图片理解) ──────────────────────────
# "gemini" or "openai"，空值时 fallback 到对应 provider 的配置
# MRDV2_VISION_PROVIDER=gemini
# MRDV2_VISION_API_KEY=
# MRDV2_VISION_BASE_URL=
# MRDV2_VISION_MODEL=
# 示例：使用 Kimi 2.5 做视频理解
# MRDV2_VISION_PROVIDER=openai
# MRDV2_VISION_API_KEY=sk-your-kimi-key
# MRDV2_VISION_BASE_URL=https://api.moonshot.cn/v1
# MRDV2_VISION_MODEL=kimi-2.5

# ── Whisper ASR ───────────────────────────────────────────────
MRDV2_WHISPER_MODEL_SIZE=medium
MRDV2_WHISPER_DEVICE=auto

# ── Storage ───────────────────────────────────────────────────
MRDV2_PROJECTS_DIR=./projects
MRDV2_EXPORTS_DIR=./projects/exports
# 允许 agent 访问的媒体目录（JSON 数组），空 = 不限制
# MRDV2_ALLOWED_MEDIA_DIRS=[]

# ── FFmpeg ────────────────────────────────────────────────────
# 留空 = 自动从 PATH 查找
# MRDV2_FFMPEG_PATH=
MRDV2_FFMPEG_MAX_INPUTS=20

# ── Export GL backend ─────────────────────────────────────────
# auto | angle-egl | swangle | egl | vulkan
# MRDV2_EXPORT_GL=auto

# ── Server ────────────────────────────────────────────────────
# MRDV2_HOST=0.0.0.0
# MRDV2_PORT=8000
# MRDV2_CORS_ORIGINS=["http://localhost:5173"]
