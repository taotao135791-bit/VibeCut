{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mrdv2.dev/schemas/timeline.schema.json",
  "title": "MrDV2 Timeline",
  "description": "MVP Timeline JSON Schema for VibeCut",
  "type": "object",
  "required": ["version", "project", "tracks"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0.0"
    },
    "project": {
      "$ref": "#/$defs/ProjectMeta"
    },
    "media_pool": {
      "type": "array",
      "items": { "$ref": "#/$defs/MediaAsset" },
      "description": "Registry of all source media files referenced by clips",
      "default": []
    },
    "tracks": {
      "type": "array",
      "items": { "$ref": "#/$defs/Track" }
    }
  },
  "$defs": {
    "ProjectMeta": {
      "type": "object",
      "required": ["name", "width", "height", "fps"],
      "properties": {
        "name": { "type": "string" },
        "width": { "type": "integer", "default": 1920 },
        "height": { "type": "integer", "default": 1080 },
        "fps": {
          "type": "number",
          "default": 30,
          "enum": [23.976, 24, 25, 29.97, 30, 50, 59.94, 60]
        }
      }
    },
    "MediaAsset": {
      "type": "object",
      "required": ["id", "path", "type"],
      "properties": {
        "id": { "type": "string", "description": "Unique ID, referenced by clips" },
        "path": { "type": "string", "description": "Absolute or project-relative file path" },
        "type": { "type": "string", "enum": ["video", "audio", "image"] },
        "duration_sec": { "type": "number", "description": "Source media duration in seconds" },
        "width": { "type": "integer" },
        "height": { "type": "integer" },
        "sample_rate": { "type": "integer" },
        "channels": { "type": "integer" }
      }
    },
    "Track": {
      "type": "object",
      "required": ["id", "type", "clips"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "audio", "subtitle", "effect"] },
        "locked": { "type": "boolean", "default": false },
        "muted": { "type": "boolean", "default": false },
        "clips": {
          "type": "array",
          "items": { "$ref": "#/$defs/Clip" }
        }
      }
    },
    "Clip": {
      "type": "object",
      "required": ["id", "type", "timeline_start_sec", "timeline_end_sec"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "audio", "subtitle", "effect"] },
        "media_id": {
          "type": "string",
          "description": "Reference to a MediaAsset.id in media_pool"
        },
        "source_in_sec": {
          "type": "number",
          "default": 0,
          "description": "In-point in the source media (seconds)"
        },
        "source_out_sec": {
          "type": "number",
          "description": "Out-point in the source media (seconds)"
        },
        "timeline_start_sec": {
          "type": "number",
          "description": "Where this clip is placed on the timeline (seconds)"
        },
        "timeline_end_sec": {
          "type": "number",
          "description": "Where this clip ends on the timeline (seconds)"
        },
        "speed": {
          "type": "number",
          "default": 1.0,
          "minimum": 0.1,
          "maximum": 16.0,
          "description": "Playback speed multiplier. 2.0 = 2x faster"
        },
        "volume": {
          "type": "number",
          "default": 1.0,
          "minimum": 0,
          "maximum": 2.0,
          "description": "Audio volume multiplier. 0=mute, 1=original, 2=boost"
        },
        "fade_in_sec": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Audio fade-in duration in seconds (0 = no fade)"
        },
        "fade_out_sec": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Audio fade-out duration in seconds (0 = no fade)"
        },
        "subtitle_text": {
          "type": "string",
          "description": "For subtitle clips - the text content to display"
        },
        "subtitle_style_ref": {
          "type": "string",
          "description": "Reference to a subtitle style preset name (e.g. 'default'). Required for subtitle clips."
        },
        "subtitle_style": {
          "$ref": "#/$defs/SubtitleStyle",
          "description": "Per-clip style overrides. Only set fields override the preset; unset fields inherit from the referenced preset."
        },
        "video_style": {
          "$ref": "#/$defs/VideoStyle"
        },
        "effect_kind": {
          "type": "string",
          "enum": ["flash", "cinematic_bars", "speed_lines", "spotlight", "callout", "sticker_text"],
          "description": "For effect clips - React-rendered effect component type"
        },
        "effect_scope": {
          "type": "string",
          "enum": ["fullscreen", "component"],
          "description": "Whether the effect covers the full frame or behaves as a positioned component"
        },
        "effect_params": {
          "$ref": "#/$defs/EffectParams"
        }
      }
    },
    "SubtitleStyle": {
      "type": "object",
      "description": "Subtitle style properties. Used both as preset definitions (all fields set) and as per-clip overrides (only overridden fields set).",
      "properties": {
        "position_x": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Horizontal center position as fraction of frame width (0=left, 1=right)"
        },
        "position_y": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Vertical center position as fraction of frame height (0=top, 1=bottom)"
        },
        "font_family": { "type": "string" },
        "font_size": { "type": "integer" },
        "color": { "type": "string", "description": "Text color (hex or CSS color)" },
        "background": { "type": "string", "description": "Background color (rgba/hex/keywords)" },
        "text_align": {
          "type": "string",
          "enum": ["left", "center", "right"]
        },
        "bold": { "type": "boolean" },
        "italic": { "type": "boolean" },
        "outline_color": { "type": "string", "description": "Text outline/stroke color" },
        "outline_width": { "type": "number", "minimum": 0, "description": "Text outline/stroke width in pixels" },
        "shadow": { "type": "string", "description": "CSS text-shadow value, e.g. '2px 2px 4px rgba(0,0,0,0.5)'" },
        "padding": { "type": "string", "description": "CSS padding value, e.g. '4px 16px'" },
        "border_radius": { "type": "number", "minimum": 0, "description": "Background border radius in pixels" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1, "description": "Overall opacity (0=transparent, 1=opaque)" },
        "letter_spacing": { "type": "number", "description": "Letter spacing in pixels" }
      }
    },
    "VideoStyle": {
      "type": "object",
      "description": "Spatial and visual properties for video/image clips (PiP, overlay, crop)",
      "properties": {
        "position_x": {
          "type": "number",
          "default": 0.5,
          "minimum": 0,
          "maximum": 1,
          "description": "Horizontal center position as fraction of frame width (0=left, 0.5=center, 1=right)"
        },
        "position_y": {
          "type": "number",
          "default": 0.5,
          "minimum": 0,
          "maximum": 1,
          "description": "Vertical center position as fraction of frame height (0=top, 0.5=center, 1=bottom)"
        },
        "width": {
          "type": "number",
          "default": 1.0,
          "minimum": 0.01,
          "maximum": 2.0,
          "description": "Width as fraction of frame width (1.0 = full width, 0.5 = half)"
        },
        "height": {
          "type": "number",
          "default": 1.0,
          "minimum": 0.01,
          "maximum": 2.0,
          "description": "Height as fraction of frame height (1.0 = full height, 0.5 = half)"
        },
        "opacity": {
          "type": "number",
          "default": 1.0,
          "minimum": 0,
          "maximum": 1,
          "description": "Opacity (0=transparent, 1=fully opaque)"
        },
        "fit": {
          "type": "string",
          "enum": ["contain", "cover", "fill"],
          "default": "contain",
          "description": "How video fits its bounding box. contain=letterbox, cover=crop to fill, fill=stretch"
        },
        "crop_left": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 0.9,
          "description": "Fraction to crop from left edge of source video"
        },
        "crop_top": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 0.9,
          "description": "Fraction to crop from top edge of source video"
        },
        "crop_right": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 0.9,
          "description": "Fraction to crop from right edge of source video"
        },
        "crop_bottom": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 0.9,
          "description": "Fraction to crop from bottom edge of source video"
        },
        "border_radius": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Border radius in pixels (0 = sharp corners)"
        }
      }
    },
    "EffectParams": {
      "type": "object",
      "description": "Parameters for React-rendered effect clips",
      "properties": {
        "intensity": { "type": "number", "minimum": 0, "maximum": 2 },
        "color": { "type": "string" },
        "accent_color": { "type": "string" },
        "direction": { "type": "string", "enum": ["left", "right", "up", "down"] },
        "label": { "type": "string" },
        "component_type": {
          "type": "string",
          "enum": ["promo_top_bar", "price_badge", "countdown_banner", "model_rate_grid", "reaction_sticker", "cta_badge", "offer_stage", "pricing_stage", "proof_stage"],
          "description": "Semantic ad component to render for component-scoped effects"
        },
        "preset_id": {
          "type": "string",
          "enum": ["lovart_promo", "cinema_dark", "clean_price_card"]
        },
        "layout_anchor": {
          "type": "string",
          "enum": ["top", "bottom", "left", "right", "center", "top_left", "top_right", "bottom_left", "bottom_right"]
        },
        "motion_preset": {
          "type": "string",
          "enum": ["pop", "slide", "pulse", "none"]
        },
        "safe_area": { "type": "number", "minimum": 0, "maximum": 0.5 },
        "avoid_regions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "z_index_policy": {
          "type": "string",
          "enum": ["below_subtitles", "above_subtitles", "top"]
        }
      }
    }
  }
}
